# ================================
# MongoDB Configuration
# ================================
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/material-management

# ================================
# Session & Authentication
# ================================
SESSION_SECRET=your_random_secret_key_here_min_32_chars_long

# ================================
# Server Configuration
# ================================
PORT=5001
NODE_ENV=development

# ================================
# Cloudinary Configuration (Cloud Image Storage)
# ================================
# Sign up for free at: https://cloudinary.com
# Get credentials from: https://console.cloudinary.com/settings/api

# Cloudinary Cloud Name (found in your dashboard)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# Cloudinary API Key (found in API Keys section)
CLOUDINARY_API_KEY=your_api_key_here

# Cloudinary API Secret (found in API Keys section)
# IMPORTANT: Keep this secret! Never commit it to version control.
CLOUDINARY_API_SECRET=your_api_secret_here

# ================================
# SECURITY NOTE
# ================================
# This .env file should NEVER be committed to version control.
# Make sure .gitignore includes .env and .env.local files.
# Copy this file to .env and fill in your actual credentials.
